SECRET_KEY=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-secure-admin-password
# Optional: set this in deployment if you are using Railway/MySQL/Postgres
# DATABASE_URL=
# Optional: use S3-compatible object storage in deployment
# STORAGE_BACKEND=s3
# S3_BUCKET=your-bucket-name
# S3_REGION=your-region
# S3_ENDPOINT_URL=
# S3_KEY_PREFIX=uploads
# S3_URL_EXPIRATION=3600
